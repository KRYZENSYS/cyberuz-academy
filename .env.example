# ===== DATABASE =====
DATABASE_URL="postgresql://user:password@host:5432/cyberuz_academy?schema=public"

# ===== AUTHENTICATION =====
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-also-change-this-min-32-chars"
BCRYPT_ROUNDS="12"

# ===== AI (GROQ) =====
GROQ_API_KEY="gsk_your_groq_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_MAX_TOKENS="2048"

# ===== EMAIL (Nodemailer) =====
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_NAME="CyberUz Academy"
SMTP_FROM_EMAIL="noreply@cyberuz.uz"

# ===== YOUTUBE API =====
YOUTUBE_API_KEY="AIzaSy_your_youtube_api_key_here"

# ===== APP CONFIG =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ===== CRON =====
CRON_SECRET="random-cron-secret-token-change-me"

# ===== OPTIONAL =====
ANALYTICS_ENABLED="true"
SENTRY_DSN=""
REDIS_URL=""