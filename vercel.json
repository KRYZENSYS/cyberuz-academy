{
  "version": 2,
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/daily-push",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/generate-content",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/update-streaks",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/cron/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}